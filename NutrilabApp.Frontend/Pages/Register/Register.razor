@page "/register"
@layout AuthLayout
@inherits RegisterBase

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-title">
            <img src="carrot.png" alt="NutriPlan" style="width:40px; height:40px; object-fit:contain;" />
            <h2>Create Account</h2>
        </div>

        @if (!IsOnline)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-3">
                <span>📵</span>
                <span>You are offline. Login is not available.</span>
            </div>
        }

        <div class="form-group">
            <label>Email</label>
            <input type="email" @bind="Email" placeholder="email@example.com" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" @bind="Password" placeholder="••••••••" />
        </div>

        <button class="btn-primary" @onclick="HandleRegister" disabled="@IsLoading">
            @(IsLoading ? "Loading..." : "Register")
        </button>

        <p class="auth-switch">
            Already have an account? <a href="/login">Login</a>
        </p>
    </div>
</div>