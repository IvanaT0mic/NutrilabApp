@page "/recipes/{Id:long}"
@inherits RecipeDetailBase

<PageTitle>@(Recipe?.Name ?? "Recipe") - NutriLab</PageTitle>

@if (IsLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
    </div>
}
else if (Recipe == null)
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">😕</div>
        <p class="mt-2">Recipe not found.</p>
        <a href="/recipes" class="btn btn-outline-success btn-sm mt-2">← Back to Library</a>
    </div>
}
else
{
    <div style="max-width:720px">

        <a href="/recipes" class="btn btn-outline-success btn-sm mb-3">← Back</a>

        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible py-2 mb-3">@SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger py-2 mb-3">@ErrorMessage</div>
        }

        @if (!string.IsNullOrEmpty(Recipe.ImageBase64))
        {
            <img src="data:image/jpeg;base64,@Recipe.ImageBase64"
                 alt="@Recipe.Name"
                 class="w-100 rounded-3 mb-3"
                 style="height:280px; object-fit:cover" />
        }
        else
        {
            <div class="w-100 rounded-3 mb-3 d-flex align-items-center justify-content-center bg-success bg-opacity-10"
                 style="height:280px; font-size:5rem">
                🍽️
            </div>
        }

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                    <h2 class="mb-0 fw-bold flex-grow-1">@Recipe.Name</h2>

                    <div class="d-flex gap-2 flex-shrink-0">
                        @* Favourite button *@
                        <button class="btn @(IsFavourite ? "btn-danger" : "btn-outline-secondary") btn-sm rounded-circle"
                                style="width:38px; height:38px"
                                title="@(IsFavourite ? "Remove from favourites" : "Add to favourites")"
                                @onclick="ToggleFavourite"
                                disabled="@IsFavouriteLoading">
                            @if (IsFavouriteLoading)
                            {
                                <span class="spinner-border spinner-border-sm" style="width:14px;height:14px"></span>
                            }
                            else
                            {
                                @(IsFavourite ? "♥" : "♡")
                            }
                        </button>

                        @* Download PDF button *@
                        <button class="btn btn-outline-success btn-sm"
                                style="height:38px"
                                title="Download as PDF"
                                @onclick="DownloadPdf"
                                disabled="@IsDownloading">
                            @if (IsDownloading)
                            {
                                <span class="spinner-border spinner-border-sm me-1" style="width:14px;height:14px"></span>
                                <span>Downloading...</span>
                            }
                            else
                            {
                                <span>⬇ PDF</span>
                            }
                        </button>

                        @* Edit button - only admin/editor *@
                        @if (CanEdit)
                        {
                            <a href="/recipes/@Recipe.Id/edit"
                               class="btn btn-outline-warning btn-sm"
                               style="height:38px; width:38px; display:flex; align-items:center; justify-content:center"
                               title="Edit recipe">
                                ✏️
                            </a>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mb-4 flex-wrap">
                    @if (Recipe.PreparationTimeMinutes.HasValue)
                    {
                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success fw-semibold px-3 py-2">
                            🕐 @Recipe.PreparationTimeMinutes min
                        </span>
                    }
                    @if (Recipe.DifficultyLvl.HasValue)
                    {
                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success fw-semibold px-3 py-2">
                            @GetDifficultyIcon(Recipe.DifficultyLvl) @GetDifficultyLabel(Recipe.DifficultyLvl)
                        </span>
                    }
                    @if (Recipe.MealCategory.HasValue)
                    {
                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success fw-semibold px-3 py-2">
                            🍽 @Recipe.MealCategory.Value.ToString()
                        </span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Recipe.Description))
                {
                    <div class="mb-4">
                        <h5 class="fw-bold border-bottom pb-2 mb-3">Description</h5>
                        <p class="text-muted lh-lg">@Recipe.Description</p>
                    </div>
                }

                @if (Recipe.Ingredients.Any())
                {
                    <div>
                        <h5 class="fw-bold border-bottom pb-2 mb-3">Ingredients</h5>
                        <ul class="list-unstyled d-flex flex-column gap-2">
                            @foreach (var ingredient in Recipe.Ingredients)
                            {
                                <li class="d-flex align-items-center justify-content-between px-3 py-2 rounded-2"
                                    style="background-color: var(--nutrilab-green-pale)">
                                    <span class="fw-semibold">
                                        <span class="text-success me-2">●</span>
                                        @ingredient.IngredientName
                                    </span>
                                    <span class="text-muted small">
                                        @ingredient.Quantity @ingredient.Unit
                                    </span>
                                </li>
                            }
                        </ul>
                    </div>
                }

            </div>
        </div>

    </div>
}
