@page "/recipes"
@inherits RecipeLibraryBase

<PageTitle>Recipe Library - NutriLab</PageTitle>

<div class="mb-4">
    <h2 class="mb-3">Recipe Library</h2>

    <div class="input-group mb-3" style="max-width: 480px">
        <span class="input-group-text bg-white">🔍</span>
        <input type="text"
               class="form-control"
               placeholder="Search for recipes..."
               @bind="SearchQuery"
               @bind:event="oninput" />
    </div>

    <div class="d-flex gap-2 flex-wrap">
        @foreach (var cat in Categories)
        {
            <button class="btn btn-sm @(ActiveCategory == cat ? "btn-success" : "btn-outline-success")"
                    style="border-radius: 20px"
                    @onclick="@(() => SetCategory(cat))">
                @cat
            </button>
        }
    </div>
</div>

@if (IsLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
        <p class="mt-2 text-muted">Loading recipes...</p>
    </div>
}
else if (!FilteredRecipes.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size: 3rem">🍽️</div>
        <p class="mt-2">No recipes found.</p>
    </div>
}
else
{
    <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-3">
        @foreach (var recipe in FilteredRecipes)
        {
            <div class="col">
                <a href="/recipes/@recipe.Id" class="card h-100 text-decoration-none text-dark shadow-sm recipe-hover">
                    @if (!string.IsNullOrEmpty(recipe.ImageBase64))
                    {
                        <img src="data:image/jpeg;base64,@recipe.ImageBase64"
                             class="card-img-top"
                             style="height:160px; object-fit:cover"
                             alt="@recipe.Name" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-success bg-opacity-10"
                             style="height:160px; font-size:3rem">
                            🍽️
                        </div>
                    }
                    <div class="card-body pb-2">
                        <h6 class="card-title fw-bold mb-1">@recipe.Name</h6>
                    </div>
                    <div class="card-footer bg-white border-0 pt-0 pb-2">
                        @if (recipe.PreparationTimeMinutes.HasValue)
                        {
                            <small class="text-success fw-semibold me-2">🕐 @recipe.PreparationTimeMinutes min</small>
                        }
                        @if (recipe.DifficultyLvl.HasValue)
                        {
                            <small class="text-success fw-semibold">@GetDifficultyIcon(recipe.DifficultyLvl.Value) @recipe.DifficultyLvl.Value.ToString()</small>
                        }
                    </div>
                </a>
            </div>
        }
    </div>
}

@code {
    private string GetDifficultyIcon(Nutrilab.Shared.Enums.DifficultyLvl lvl) => lvl switch
    {
        Nutrilab.Shared.Enums.DifficultyLvl.EASY => "✅",
        Nutrilab.Shared.Enums.DifficultyLvl.MEDIUM => "⚡",
        Nutrilab.Shared.Enums.DifficultyLvl.HARD => "🔥",
        _ => ""
    };
}
