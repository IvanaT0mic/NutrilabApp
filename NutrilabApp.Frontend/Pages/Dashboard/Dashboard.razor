@page "/dashboard"
@inherits DashboardBase

<PageTitle>Dashboard - NutriPlan</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">Welcome!</h2>
        <small class="text-muted">@Email</small>
    </div>
    <span class="badge bg-success fs-6">@PrimaryRole</span>
</div>

@if (IsAdminOrMaintainer)
{
    <!-- Stat kartice -->
    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon">👥</div>
                    <div>
                        <div class="stat-value">@UserCount</div>
                        <div class="stat-label">Total Users</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="stat-icon">📖</div>
                    <div>
                        <div class="stat-value">@RecipeCount</div>
                        <div class="stat-label">Recipes</div>
                    </div>
                </div>
            </div>
        </div>
        @if (IsAdmin)
        {
            <div class="col-sm-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="stat-icon">🔐</div>
                        <div>
                            <div class="stat-value">@RoleCount</div>
                            <div class="stat-label">Roles</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Quick actions -->
    <h5 class="mb-3">Quick Actions</h5>
    <div class="row g-3">
        <div class="col-sm-4">
            <a href="/users" class="card shadow-sm text-decoration-none text-dark h-100">
                <div class="card-body d-flex align-items-center gap-2">
                    <span style="font-size:1.4rem">👥</span>
                    <span class="fw-semibold">Manage Users</span>
                    <span class="ms-auto text-success">→</span>
                </div>
            </a>
        </div>
        <div class="col-sm-4">
            <a href="/recipes" class="card shadow-sm text-decoration-none text-dark h-100">
                <div class="card-body d-flex align-items-center gap-2">
                    <span style="font-size:1.4rem">📖</span>
                    <span class="fw-semibold">View Recipes</span>
                    <span class="ms-auto text-success">→</span>
                </div>
            </a>
        </div>
        @if (IsAdmin)
        {
            <div class="col-sm-4">
                <a href="/roles" class="card shadow-sm text-decoration-none text-dark h-100">
                    <div class="card-body d-flex align-items-center gap-2">
                        <span style="font-size:1.4rem">🔐</span>
                        <span class="fw-semibold">Manage Roles</span>
                        <span class="ms-auto text-success">→</span>
                    </div>
                </a>
            </div>
        }
    </div>
}
else
{
    <h5 class="mb-3">Recent Recipes</h5>
    @if (IsLoadingRecipes)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-success" role="status"></div>
        </div>
    }
    else if (!RecentRecipes.Any())
    {
        <p class="text-muted">No recipes yet.</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var recipe in RecentRecipes)
            {
                <div class="col-sm-6 col-md-4">
                    <a href="/recipes/@recipe.Id" class="card shadow-sm h-100 text-decoration-none text-dark">
                        @if (!string.IsNullOrEmpty(recipe.ImageBase64))
                        {
                            <img src="data:image/jpeg;base64,@recipe.ImageBase64"
                                 class="card-img-top recipe-card-img" alt="@recipe.Name" />
                        }
                        else
                        {
                            <div class="recipe-placeholder">🍽️</div>
                        }
                        <div class="card-body">
                            <h6 class="card-title mb-1">@recipe.Name</h6>
                            @if (!string.IsNullOrEmpty(recipe.Description))
                            {
                                <p class="card-text text-muted small">
                                    @(recipe.Description.Length > 80 ? recipe.Description[..80] + "..." : recipe.Description)
                                </p>
                            }
                        </div>
                    </a>
                </div>
            }
        </div>
    }
}