@page "/ingredients"
@inherits IngredientsBase

<PageTitle>Ingredients - NutriLab</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">Ingredients</h2>
        <small class="text-muted">@Ingredients.Count ingredient(s) available</small>
    </div>
    @if (!IsAdding)
    {
        <button class="btn btn-success" @onclick="StartAdding">
            + Add Ingredient
        </button>
    }
</div>

@if (IsAdding)
{
    <div class="card shadow-sm mb-4 border-success">
        <div class="card-body">
            <h6 class="card-title text-success mb-3">➕ New Ingredient</h6>
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-5">
                    <label class="form-label small fw-semibold">Name <span class="text-danger">*</span></label>
                    <input type="text"
                           class="form-control"
                           placeholder="e.g. Chicken breast"
                           @bind="NewName"
                           @bind:event="oninput"
                           @onkeyup="@(async e => { if (e.Key == "Enter") await SaveNewIngredient(); })" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label small fw-semibold">Unit</label>
                    <input type="text"
                           class="form-control"
                           placeholder="e.g. g, ml, pcs"
                           @bind="NewUnit"
                           @bind:event="oninput" />
                </div>
                <div class="col-12 col-md-3">
                    <div class="d-flex gap-2">
                        <button class="btn btn-success flex-grow-1"
                                @onclick="SaveNewIngredient"
                                disabled="@IsSaving">
                            @(IsSaving ? "Saving..." : "✓ Save")
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="CancelAdding" disabled="@IsSaving">
                            ✕
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="input-group mb-3" style="max-width: 400px">
    <span class="input-group-text bg-white">🔍</span>
    <input type="text"
           class="form-control"
           placeholder="Search ingredients..."
           @bind="SearchQuery"
           @bind:event="oninput" />
</div>

@if (IsLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
        <p class="mt-2 text-muted">Loading ingredients...</p>
    </div>
}
else if (!FilteredIngredients.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size: 3rem">🥦</div>
        <p class="mt-2">
            @if (string.IsNullOrWhiteSpace(SearchQuery))
            {
                <span>No ingredients yet. Add the first one!</span>
            }
            else
            {
                <span>No ingredients found for "@SearchQuery".</span>
            }
        </p>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:50px">#</th>
                        <th>Name</th>
                        <th>Unit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ingredient in FilteredIngredients)
                    {
                        <tr>
                            <td class="text-muted small">@ingredient.Id</td>
                            <td class="fw-semibold">@ingredient.Name</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(ingredient.Unit))
                                {
                                    <span class="badge"
                                          style="background-color: var(--nutrilab-green-light); color: var(--nutrilab-green)">
                                        @ingredient.Unit
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic small">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
