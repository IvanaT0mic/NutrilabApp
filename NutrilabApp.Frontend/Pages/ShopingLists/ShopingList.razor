@page "/shopping-lists"
@using NutrilabApp.Frontend.Pages.ShoppingLists
@inherits ShoppingListBase

<PageTitle>Shopping Lists - NutriLab</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">Shopping Lists</h2>
        <small class="text-muted">@Lists.Count list(s)</small>
    </div>
    <button class="btn btn-success btn-sm" @onclick="@(() => ShowCreateForm = !ShowCreateForm)">
        + New List
    </button>
</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}
@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success">@SuccessMessage</div>
}

@if (ShowCreateForm)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3">
            <h6 class="fw-bold mb-3">New Shopping List</h6>
            <div class="d-flex gap-2">
                <input type="text"
                       class="form-control"
                       placeholder="List name (e.g. Weekly groceries)"
                       @bind="NewListName"
                       @onkeydown="@(async (e) => { if (e.Key == "Enter") await CreateList(); })" />
                <button class="btn btn-success px-3" @onclick="CreateList" disabled="@IsCreating">
                    @(IsCreating ? "Creating..." : "Create")
                </button>
                <button class="btn btn-outline-secondary px-3" @onclick="@(() => ShowCreateForm = false)">
                    Cancel
                </button>
            </div>
        </div>
    </div>
}

@if (IsLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-success" role="status"></div>
        <p class="mt-2 text-muted">Loading...</p>
    </div>
}
else if (!Lists.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🛒</div>
        <p class="mt-2">No shopping lists yet.</p>
        <button class="btn btn-outline-success btn-sm mt-2" @onclick="@(() => ShowCreateForm = true)">
            Create your first list
        </button>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var list in Lists)
        {
            <div class="col-sm-6 col-md-4">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start justify-content-between mb-2">
                            <div>
                                <h6 class="fw-bold mb-1">@list.Name</h6>
                                <small class="text-muted">@list.ItemCount item(s)</small>
                            </div>
                            <button class="btn btn-sm btn-outline-danger py-0 px-2 ms-2"
                                    title="Delete list"
                                    @onclick="@(() => DeleteList(list.Id))">
                                🗑
                            </button>
                        </div>
                        <a href="/shopping-lists/@list.Id" class="btn btn-outline-success btn-sm mt-auto">
                            Open →
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
