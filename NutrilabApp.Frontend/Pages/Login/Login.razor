@page "/login"
@layout AuthLayout
@inherits LoginBase

<div class="auth-wrapper">
    <div class="auth-card">
        <h2 class="auth-title">NutriPlan 🥗</h2>

        @if (!IsOnline)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-3">
                <span>📵</span>
                <span>You are offline. Login is not available.</span>
            </div>
        }

        <div class="form-group">
            <label>Email</label>
            <input type="email" @bind="Email" placeholder="email@example.com" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" @bind="Password" placeholder="••••••••" />
        </div>

        <button class="btn-primary" @onclick="HandleLogin" disabled="@IsLoading">
            @(IsLoading ? "Loading..." : "Login")
        </button>

        <p class="auth-switch">
            Don't have an account? <a href="/register">Register</a>
        </p>
    </div>
</div>