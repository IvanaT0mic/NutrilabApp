@page "/home"
@inherits HomeBase

<div class="home-header">
    <h2>Welcome back 👋</h2>
    <p class="subtitle">@Email</p>
</div>

<h4 class="section-title">Recent Recipes</h4>

@if (IsLoading)
{
    <p>Loading...</p>
}
else if (!Recipes.Any())
{
    <p class="empty">No recipes yet.</p>
}
else
{
    <div class="recipe-grid">
        @foreach (var recipe in Recipes)
        {
            <a href="/recipes/@recipe.Id" class="recipe-card">
                <h5>@recipe.Name</h5>
                <p>@recipe.Description</p>
                <span class="ingredient-count">@recipe.Ingredients.Count ingredients</span>
            </a>
        }
    </div>
}