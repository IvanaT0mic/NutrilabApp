@using NutrilabApp.Frontend.Layout.NavigationLayout
@using NutrilabApp.Frontend.Services.SnackBarServices
@inherits MainLayoutBase

@if (!IsReady)
{
    <div class="d-flex align-items-center justify-content-center vh-100">
        <div class="spinner-border text-success" role="status"></div>
    </div>
}
else
{
    <aside class="sidebar-desktop d-none d-lg-flex flex-column">
        <div class="sidebar-logo">
            <img src="carrot.png" alt="NutriPlan" style="width:28px; height:28px; object-fit:contain;" />
            NutriPlan
        </div>
        <nav class="sidebar-nav nav flex-column">
            <NavDrawer />
        </nav>
        <div class="sidebar-footer">
            <UserFooter />
        </div>
    </aside>

    <nav class="mobile-topbar d-flex d-lg-none">
        <span class="mobile-topbar-title">
            <img src="carrot.png" alt="NutriLab" style="width:25px; height:25px; object-fit:contain;" />
            <h2>NutriPlan</h2>
        </span>
        <button class="btn btn-sm btn-outline-light" @onclick="ToggleMenu">☰</button>
    </nav>

    @if (_menuOpen)
    {
        <div class="drawer-overlay" @onclick="ToggleMenu"></div>
        <div class="drawer-panel">
            <div class="drawer-header">
                <button class="btn-close btn-close-white" @onclick="ToggleMenu"></button>
            </div>
            <div class="drawer-nav">
                <NavDrawer OnNavigate="CloseMenu" />
            </div>
            <div class="drawer-footer">
                <UserFooter />
            </div>
        </div>
    }

    <main class="main-content">
        @Body
    </main>

    <Snackbar />
}

@code {
    private bool _menuOpen = false;
    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;
}